#!/usr/bin/env bash
# claude-account — multi-account manager for Claude Code
set -euo pipefail

ACCOUNTS_DIR="${CLAUDE_ACCOUNTS_DIR:-$HOME/.claude-accounts}"
ACCOUNTS_DB="$ACCOUNTS_DIR/accounts"
LINKS_FILE="$ACCOUNTS_DIR/links"
CURRENT_FILE="$ACCOUNTS_DIR/current"
CLAUDE_JSON="$HOME/.claude.json"

_ensure_dirs() {
  mkdir -p "$ACCOUNTS_DIR" "$ACCOUNTS_DB"
  touch "$LINKS_FILE"
}

# ---------------------------------------------------------------------------
# add <name>
# ---------------------------------------------------------------------------
_keychain_save() {
  local dest="$1"
  local data
  data=$(security find-generic-password -s "Claude Code-credentials" -w 2>/dev/null) || true
  if [[ -n "$data" ]]; then
    echo "$data" > "$dest"
  fi
}

cmd_add() {
  local name="${1:-}"
  [[ -z "$name" ]] && { echo "Usage: claude-account add <name>"; exit 1; }
  [[ ! -f "$CLAUDE_JSON" ]] && {
    echo "Error: ~/.claude.json not found. Log in to Claude first (run: claude)."
    exit 1
  }
  _ensure_dirs
  mkdir -p "$ACCOUNTS_DB/$name"
  cp "$CLAUDE_JSON" "$ACCOUNTS_DB/$name/credentials"
  _keychain_save "$ACCOUNTS_DB/$name/keychain"
  echo "$name" > "$CURRENT_FILE"
  echo "Saved current credentials as account '$name'."
}

# ---------------------------------------------------------------------------
# list
# ---------------------------------------------------------------------------
cmd_list() {
  _ensure_dirs
  local current=""
  [[ -f "$CURRENT_FILE" ]] && current=$(cat "$CURRENT_FILE")
  local found=false
  for d in "$ACCOUNTS_DB"/*/; do
    [[ -d "$d" ]] || continue
    found=true
    local name
    name=$(basename "$d")
    if [[ "$name" == "$current" ]]; then
      echo "* $name  (active)"
    else
      echo "  $name"
    fi
  done
  $found || echo "No accounts saved yet. Run: claude-account add <name>"
}

# ---------------------------------------------------------------------------
# use <name>
# ---------------------------------------------------------------------------
cmd_use() {
  local name="${1:-}"
  [[ -z "$name" ]] && { echo "Usage: claude-account use <name>"; exit 1; }
  local cred_file="$ACCOUNTS_DB/$name/credentials"
  [[ ! -f "$cred_file" ]] && {
    echo "Error: account '$name' not found. Run: claude-account list"
    exit 1
  }
  # Persist current credentials before switching
  local current=""
  [[ -f "$CURRENT_FILE" ]] && current=$(cat "$CURRENT_FILE")
  if [[ -n "$current" && -f "$CLAUDE_JSON" && "$current" != "$name" ]]; then
    mkdir -p "$ACCOUNTS_DB/$current"
    cp "$CLAUDE_JSON" "$ACCOUNTS_DB/$current/credentials"
    _keychain_save "$ACCOUNTS_DB/$current/keychain"
  fi
  cp "$cred_file" "$CLAUDE_JSON"
  # Swap keychain to the new account's token
  local keychain_file="$ACCOUNTS_DB/$name/keychain"
  if [[ -f "$keychain_file" ]]; then
    security add-generic-password \
      -s "Claude Code-credentials" \
      -a "$(whoami)" \
      -w "$(cat "$keychain_file")" \
      -U 2>/dev/null || true
  fi
  echo "$name" > "$CURRENT_FILE"
  echo "Switched to account '$name'."
}

# ---------------------------------------------------------------------------
# link [name]  — associates the current directory with an account
# ---------------------------------------------------------------------------
cmd_link() {
  local name="${1:-}"
  if [[ -z "$name" ]]; then
    [[ -f "$CURRENT_FILE" ]] && name=$(cat "$CURRENT_FILE")
    [[ -z "$name" ]] && {
      echo "Usage: claude-account link <name>"
      echo "       (or switch to an account first with: claude-account use <name>)"
      exit 1
    }
  fi
  [[ ! -d "$ACCOUNTS_DB/$name" ]] && {
    echo "Error: account '$name' not found. Run: claude-account list"
    exit 1
  }
  _ensure_dirs
  local dir="$PWD"
  # Remove any existing link for this directory
  if [[ -f "$LINKS_FILE" ]]; then
    local tmp
    tmp=$(mktemp)
    grep -vF "$dir " "$LINKS_FILE" > "$tmp" || true
    mv "$tmp" "$LINKS_FILE"
  fi
  echo "$dir $name" >> "$LINKS_FILE"
  echo "Linked '$dir' → account '$name'."
}

# ---------------------------------------------------------------------------
# unlink  — removes the directory link for the current directory
# ---------------------------------------------------------------------------
cmd_unlink() {
  local dir="$PWD"
  if [[ -f "$LINKS_FILE" ]]; then
    local tmp
    tmp=$(mktemp)
    grep -vF "$dir " "$LINKS_FILE" > "$tmp" || true
    mv "$tmp" "$LINKS_FILE"
  fi
  echo "Removed link for '$dir'."
}

# ---------------------------------------------------------------------------
# remove <name>
# ---------------------------------------------------------------------------
cmd_remove() {
  local name="${1:-}"
  [[ -z "$name" ]] && { echo "Usage: claude-account remove <name>"; exit 1; }
  [[ ! -d "$ACCOUNTS_DB/$name" ]] && {
    echo "Error: account '$name' not found."
    exit 1
  }
  rm -rf "${ACCOUNTS_DB:?}/$name"
  # Remove directory links pointing to this account
  if [[ -f "$LINKS_FILE" ]]; then
    local tmp
    tmp=$(mktemp)
    grep -v " $name$" "$LINKS_FILE" > "$tmp" || true
    mv "$tmp" "$LINKS_FILE"
  fi
  # Clear current marker if we removed the active account
  local current=""
  [[ -f "$CURRENT_FILE" ]] && current=$(cat "$CURRENT_FILE")
  [[ "$current" == "$name" ]] && rm -f "$CURRENT_FILE"
  echo "Removed account '$name'."
}

# ---------------------------------------------------------------------------
# status
# ---------------------------------------------------------------------------
cmd_status() {
  _ensure_dirs
  local current=""
  [[ -f "$CURRENT_FILE" ]] && current=$(cat "$CURRENT_FILE")
  local current_dir=""
  [[ -f "$ACCOUNTS_DIR/current-dir" ]] && current_dir=$(cat "$ACCOUNTS_DIR/current-dir")
  if [[ -n "$current" ]]; then
    echo "Active account : $current"
    [[ -n "$current_dir" ]] && echo "Activated from : $current_dir"
  else
    echo "Active account : (none)"
  fi

  # Show which account's token is currently in the keychain
  local keychain_token=""
  keychain_token=$(security find-generic-password -s "Claude Code-credentials" -w 2>/dev/null) || true
  if [[ -n "$keychain_token" ]]; then
    local keychain_account="(unknown)"
    for d in "$ACCOUNTS_DB"/*/; do
      [[ -d "$d" ]] || continue
      local kf="$d/keychain"
      [[ -f "$kf" ]] || continue
      local saved
      saved=$(cat "$kf")
      if [[ "$saved" == "$keychain_token" ]]; then
        keychain_account=$(basename "$d")
        break
      fi
    done
    echo "Keychain token : $keychain_account"
  else
    echo "Keychain token : (none)"
  fi

  if [[ -f "$LINKS_FILE" ]]; then
    local linked
    linked=$(grep -F "$PWD " "$LINKS_FILE" 2>/dev/null | awk '{print $2}' | head -1 || true)
    if [[ -n "$linked" ]]; then
      echo "Directory link : $linked"
    else
      echo "Directory link : (none for $PWD)"
    fi
  fi

  # Show hook status
  local settings_file="$HOME/.claude/settings.json"
  if [[ -f "$settings_file" ]] && grep -q "claude-accounts-hook" "$settings_file" 2>/dev/null; then
    echo "Session hook    : installed"
  else
    echo "Session hook    : not installed (run install.sh)"
  fi
}

# ---------------------------------------------------------------------------
# usage
# ---------------------------------------------------------------------------
usage() {
  cat <<'EOF'
claude-account — multi-account manager for Claude Code

Usage:
  claude-account add <name>       Save current ~/.claude.json as <name>
  claude-account list             List all saved accounts
  claude-account use <name>       Switch to <name> globally
  claude-account link [name]      Link current directory to <name>
  claude-account unlink           Remove directory link for current directory
  claude-account remove <name>    Delete account <name>
  claude-account status           Show active account and directory link
  claude-account doctor           Check installation and diagnose issues
  claude-account help             Show this help

Credentials are stored in ~/.claude-accounts/ and never in your repo.
EOF
}

# ---------------------------------------------------------------------------
# Shared helper: is this an unmodified real claude binary?
# ---------------------------------------------------------------------------
_is_real_claude_bin() {
  local bin="$1"
  [[ -x "$bin" ]] || return 1
  ! grep -qI "claude-accounts" "$bin" 2>/dev/null || return 1
  return 0
}

# Extended search for the real claude, mirroring bin/claude logic.
_locate_real_claude() {
  local skip_dir="${1:-}"

  # PATH search
  while IFS=':' read -ra dirs; do
    for dir in "${dirs[@]}"; do
      [[ -z "$dir" ]] && dir="."
      local abs=""
      abs="$(cd "$dir" 2>/dev/null && pwd)" || continue
      [[ -n "$skip_dir" && "$abs" == "$skip_dir" ]] && continue
      _is_real_claude_bin "$abs/claude" && { echo "$abs/claude"; return 0; }
    done
  done <<< "$PATH"

  # Common fixed locations for binary installs
  local c
  for c in /usr/local/bin/claude /opt/homebrew/bin/claude /usr/bin/claude \
            "$HOME/.local/bin/claude" "$HOME/bin/claude"; do
    _is_real_claude_bin "$c" && { echo "$c"; return 0; }
  done

  return 1
}

# ---------------------------------------------------------------------------
# doctor — checks the full installation and reports problems
# ---------------------------------------------------------------------------
cmd_doctor() {
  local fix_mode=false
  [[ "${1:-}" == "--fix" ]] && fix_mode=true

  local ok=true
  local REAL_PATH_FILE="$ACCOUNTS_DIR/real-path"
  local wrapper_dir=""

  echo "claude-accounts doctor"
  echo "----------------------"

  # 1. Wrapper in PATH
  local wrapper
  wrapper=$(command -v claude 2>/dev/null || true)
  if [[ -z "$wrapper" ]]; then
    echo "FAIL  'claude' not found in PATH"
    ok=false
  elif grep -qI "claude-accounts" "$wrapper" 2>/dev/null; then
    echo "OK    claude wrapper: $wrapper"
    wrapper_dir="$(cd "$(dirname "$wrapper")" && pwd)"
  else
    echo "WARN  '$wrapper' is not the claude-accounts wrapper"
    echo "      Make sure ~/.claude-accounts/bin comes before other PATH entries"
    ok=false
  fi

  # 2. Real claude path
  if [[ -f "$REAL_PATH_FILE" ]]; then
    local recorded
    recorded=$(cat "$REAL_PATH_FILE")
    if _is_real_claude_bin "$recorded"; then
      echo "OK    real claude:   $recorded"
    else
      echo "FAIL  recorded path not usable: $recorded"
      ok=false
    fi
  else
    echo "FAIL  $REAL_PATH_FILE not found"
    ok=false

    # Attempt auto-fix
    local found=""
    if found=$(_locate_real_claude "$wrapper_dir"); then
      if $fix_mode; then
        echo "$found" > "$REAL_PATH_FILE"
        echo "FIX   wrote $found → $REAL_PATH_FILE"
        ok=true
      else
        echo "      Found candidate: $found"
        echo "      Run: claude-account doctor --fix   (to apply automatically)"
        echo "      Or:  echo \"$found\" > $REAL_PATH_FILE"
      fi
    else
      echo "      Could not auto-locate real claude binary."
      echo "      Run: echo /path/to/claude > $REAL_PATH_FILE"
    fi
  fi

  # 3. ~/.claude.json
  if [[ -f "$CLAUDE_JSON" ]]; then
    echo "OK    credentials:   $CLAUDE_JSON ($(wc -c < "$CLAUDE_JSON") bytes)"
  else
    echo "WARN  $CLAUDE_JSON not found — run 'claude' to log in first"
  fi

  # 4. Saved accounts
  _ensure_dirs
  local n=0
  for d in "$ACCOUNTS_DB"/*/; do
    [[ -d "$d" ]] && n=$((n + 1))
  done
  echo "OK    saved accounts: $n"

  # 5. Directory links
  local links=0
  [[ -f "$LINKS_FILE" ]] && links=$(grep -c . "$LINKS_FILE" 2>/dev/null || true)
  echo "OK    directory links: $links"

  # 6. UserPromptSubmit hook
  local settings_file="$HOME/.claude/settings.json"
  if [[ -f "$settings_file" ]] && grep -q "claude-accounts-hook" "$settings_file" 2>/dev/null; then
    echo "OK    session hook:  configured in $settings_file"
  else
    echo "FAIL  UserPromptSubmit hook not configured"
    echo "      Re-run install.sh to add the hook, or add it manually to $settings_file"
    ok=false
  fi

  # 7. Hook script exists and is executable
  local hook_bin="$ACCOUNTS_DIR/bin/claude-accounts-hook"
  if [[ -x "$hook_bin" ]]; then
    echo "OK    hook script:   $hook_bin"
  else
    echo "FAIL  hook script not found or not executable: $hook_bin"
    echo "      Re-run install.sh"
    ok=false
  fi

  # 8. SessionEnd hook
  if [[ -f "$settings_file" ]] && grep -q "claude-accounts-session-end" "$settings_file" 2>/dev/null; then
    echo "OK    session-end:   configured in $settings_file"
  else
    echo "FAIL  SessionEnd hook not configured"
    ok=false
    if $fix_mode; then
      local se_cmd="$ACCOUNTS_DIR/bin/claude-accounts-session-end"
      if [[ -f "$settings_file" ]]; then
        python3 -c "
import json
with open('$settings_file') as f:
    s = json.load(f)
hooks = s.setdefault('hooks', {})
se = hooks.setdefault('SessionEnd', [])
se.append({'matcher': '*', 'hooks': [{'type': 'command', 'command': '$se_cmd'}]})
with open('$settings_file', 'w') as f:
    json.dump(s, f, indent=2)
    f.write('\n')
" && echo "FIX   added SessionEnd hook to $settings_file" \
      || echo "WARN  could not update $settings_file"
      else
        echo "      Re-run install.sh to add the hook"
      fi
    else
      echo "      Re-run install.sh or run: claude-account doctor --fix"
    fi
  fi

  # 9. Session-end script exists and is executable
  local se_bin="$ACCOUNTS_DIR/bin/claude-accounts-session-end"
  if [[ -x "$se_bin" ]]; then
    echo "OK    session-end:   $se_bin"
  else
    echo "FAIL  session-end script not found or not executable: $se_bin"
    echo "      Re-run install.sh"
    ok=false
  fi

  echo ""
  if $ok; then
    echo "Everything looks good."
  else
    echo "Issues found — see FAIL lines above."
  fi
}

# ---------------------------------------------------------------------------
# dispatch
# ---------------------------------------------------------------------------
case "${1:-}" in
  add)     shift; cmd_add "$@" ;;
  list)    cmd_list ;;
  use)     shift; cmd_use "$@" ;;
  link)    shift; cmd_link "$@" ;;
  unlink)  cmd_unlink ;;
  remove)  shift; cmd_remove "$@" ;;
  status)  cmd_status ;;
  doctor)  shift; cmd_doctor "$@" ;;
  -h|--help|help|"") usage ;;
  *) echo "Unknown command: $1"; echo; usage; exit 1 ;;
esac
