#!/usr/bin/env bash
# claude-accounts-session-end — SessionEnd hook
# Auto-saves the current session's credentials back to the linked account's
# storage so that OAuth token refreshes (e.g. after /login) are persisted
# without requiring a manual `claude-account add`.

ACCOUNTS_DIR="${CLAUDE_ACCOUNTS_DIR:-$HOME/.claude-accounts}"
LINKS_FILE="$ACCOUNTS_DIR/links"
LOCKDIR="$ACCOUNTS_DIR/.lock"
CLAUDE_JSON="$HOME/.claude.json"

# Determine project directory from hook env
PROJECT_DIR="${CLAUDE_PROJECT_DIR:-$PWD}"

# Walk up from PROJECT_DIR to find a linked account
linked=""
if [[ -f "$LINKS_FILE" ]]; then
  dir="$PROJECT_DIR"
  while true; do
    match=$(grep -F "$dir " "$LINKS_FILE" 2>/dev/null | awk '{print $2}' | head -1)
    [[ -n "$match" ]] && { linked="$match"; break; }
    [[ "$dir" == "/" ]] && break
    dir="$(dirname "$dir")"
  done
fi

[[ -z "$linked" ]] && exit 0

ACCOUNT_DIR="$ACCOUNTS_DIR/accounts/$linked"
[[ -d "$ACCOUNT_DIR" ]] || exit 0

# Acquire filesystem lock
_lock()   { while ! mkdir "$LOCKDIR" 2>/dev/null; do sleep 0.05; done; }
_unlock() { rmdir "$LOCKDIR" 2>/dev/null || true; }
trap _unlock EXIT

_lock

# Save credentials if they differ from the stored copy
if [[ -f "$CLAUDE_JSON" ]]; then
  if ! diff -q "$CLAUDE_JSON" "$ACCOUNT_DIR/credentials" >/dev/null 2>&1; then
    cp "$CLAUDE_JSON" "$ACCOUNT_DIR/credentials" 2>/dev/null || true
  fi
fi

# Save keychain token if it differs from the stored copy (macOS only)
if command -v security >/dev/null 2>&1; then
  token=$(security find-generic-password -s "Claude Code-credentials" -w 2>/dev/null) || true
  if [[ -n "$token" ]]; then
    stored=""
    [[ -f "$ACCOUNT_DIR/keychain" ]] && stored=$(cat "$ACCOUNT_DIR/keychain")
    if [[ "$token" != "$stored" ]]; then
      echo "$token" > "$ACCOUNT_DIR/keychain" 2>/dev/null || true
    fi
  fi
fi

_unlock
