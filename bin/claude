#!/usr/bin/env bash
# claude — wrapper that auto-switches Claude.ai accounts by project directory.
#
# Requires install.sh to have been run first; it records the real claude
# binary path in ~/.claude-accounts/real-path.

ACCOUNTS_DIR="${CLAUDE_ACCOUNTS_DIR:-$HOME/.claude-accounts}"
ACCOUNTS_DB="$ACCOUNTS_DIR/accounts"
LINKS_FILE="$ACCOUNTS_DIR/links"
CURRENT_FILE="$ACCOUNTS_DIR/current"
REAL_PATH_FILE="$ACCOUNTS_DIR/real-path"
CLAUDE_JSON="$HOME/.claude.json"

# Set CLAUDE_ACCOUNTS_DEBUG=1 to trace wrapper decisions.
_debug() {
  [[ "${CLAUDE_ACCOUNTS_DEBUG:-0}" == "1" ]] && echo "[claude-accounts] $*" >&2 || true
}

# ---------------------------------------------------------------------------
# Find the real claude binary. Resolution order:
#   1. $CLAUDE_REAL env var (manual override)
#   2. ~/.claude-accounts/real-path (written by install.sh)
#   3. PATH search excluding our own directory
# ---------------------------------------------------------------------------
_real_claude() {
  # 1. Explicit override
  if [[ -n "${CLAUDE_REAL:-}" ]]; then
    if [[ -x "$CLAUDE_REAL" ]]; then
      _debug "using CLAUDE_REAL override: $CLAUDE_REAL"
      echo "$CLAUDE_REAL"
      return 0
    fi
    echo "claude-accounts: CLAUDE_REAL='$CLAUDE_REAL' is not executable." >&2
    return 1
  fi

  # 2. Path recorded by install.sh
  if [[ -f "$REAL_PATH_FILE" ]]; then
    local recorded
    recorded=$(cat "$REAL_PATH_FILE")
    if [[ -x "$recorded" ]]; then
      _debug "using recorded real-path: $recorded"
      echo "$recorded"
      return 0
    fi
    _debug "recorded path '$recorded' no longer executable; falling back to PATH search"
  fi

  # 3. PATH search (skipping self) + common fixed locations
  local self
  self="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")"
  local self_dir
  self_dir="$(cd "$(dirname "$self")" && pwd)"

  _candidate_ok() {
    local c="$1"
    [[ -x "$c" ]] || return 1
    ! grep -qI "claude-accounts" "$c" 2>/dev/null || return 1
    return 0
  }

  local found=""

  # 3a. PATH search
  while IFS=':' read -ra dirs; do
    for dir in "${dirs[@]}"; do
      [[ -z "$dir" ]] && dir="."
      local abs_dir
      abs_dir="$(cd "$dir" 2>/dev/null && pwd)" || continue
      [[ "$abs_dir" == "$self_dir" ]] && continue
      if _candidate_ok "$abs_dir/claude"; then
        found="$abs_dir/claude"
        break 2
      fi
    done
  done <<< "$PATH"

  # 3b. Common fixed locations for binary installs
  if [[ -z "$found" ]]; then
    local c
    for c in /usr/local/bin/claude /opt/homebrew/bin/claude /usr/bin/claude \
              "$HOME/.local/bin/claude" "$HOME/bin/claude"; do
      _candidate_ok "$c" && { found="$c"; break; }
    done
  fi

  if [[ -n "$found" ]]; then
    _debug "found real claude: $found"
    echo "$found" > "$REAL_PATH_FILE" 2>/dev/null || true
    echo "$found"
    return 0
  fi

  cat >&2 <<EOF
claude-accounts: cannot find the real claude binary.

Resolution order tried:
  1. \$CLAUDE_REAL env var        (not set)
  2. $REAL_PATH_FILE
     (missing or not executable)
  3. PATH + common locations     (not found)

To fix:
  a) Re-run the installer (it will prompt you for the path):
       bash /path/to/claude-accounts/install.sh

  b) Record the path manually:
       echo /path/to/real/claude > $REAL_PATH_FILE

  c) One-shot override:
       CLAUDE_REAL=/path/to/real/claude claude
EOF
  return 1
}

# ---------------------------------------------------------------------------
# Walk from PWD up to / looking for a directory→account link.
# ---------------------------------------------------------------------------
_find_linked_account() {
  [[ -f "$LINKS_FILE" ]] || return 0
  local dir="$PWD"
  while true; do
    local match=""
    match=$(grep -F "$dir " "$LINKS_FILE" 2>/dev/null | awk '{print $2}' | head -1) || true
    if [[ -n "$match" ]]; then
      echo "$match"
      return 0
    fi
    [[ "$dir" == "/" ]] && break
    dir="$(dirname "$dir")"
  done
  return 0
}

# ---------------------------------------------------------------------------
# Swap ~/.claude.json with a named account's saved credentials.
# ---------------------------------------------------------------------------
_activate_account() {
  local name="$1"
  local cred_file="$ACCOUNTS_DB/$name/credentials"

  if [[ ! -f "$cred_file" ]]; then
    echo "claude-accounts: account '$name' is linked here but has no saved credentials." >&2
    echo "  Run: claude-account list" >&2
    return 1
  fi

  # Persist the currently active account's credentials before switching
  local current=""
  [[ -f "$CURRENT_FILE" ]] && current=$(cat "$CURRENT_FILE") || true
  if [[ -n "$current" && "$current" != "$name" && -f "$CLAUDE_JSON" ]]; then
    mkdir -p "$ACCOUNTS_DB/$current"
    cp "$CLAUDE_JSON" "$ACCOUNTS_DB/$current/credentials" || true
    _debug "saved credentials for '$current'"
  fi

  cp "$cred_file" "$CLAUDE_JSON" || {
    echo "claude-accounts: failed to write credentials for '$name' to $CLAUDE_JSON" >&2
    return 1
  }
  echo "$name" > "$CURRENT_FILE" || true
  _debug "activated account '$name'"
  return 0
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------
main() {
  local linked=""
  linked=$(_find_linked_account) || true

  if [[ -n "$linked" ]]; then
    local current=""
    [[ -f "$CURRENT_FILE" ]] && current=$(cat "$CURRENT_FILE") || true
    _debug "directory linked to '$linked' (active: '${current:-none}')"
    if [[ "$linked" != "$current" ]]; then
      _activate_account "$linked" || true
    fi
  fi

  local real_bin=""
  real_bin=$(_real_claude) || exit 1

  _debug "exec: $real_bin $*"
  exec "$real_bin" "$@"
}

main "$@"
